# Application
PROJECT_NAME="Studio OS"
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

# Security
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
INVITE_TOKEN_EXPIRE_DAYS=7

# Public frontend URL, used to build member invitation links
FRONTEND_URL=http://localhost:5173

# Database
POSTGRES_USER=studio
POSTGRES_PASSWORD=studio
POSTGRES_DB=studio_os
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Optional: kompletter DB-Override (z.B. für Tests mit SQLite)
# DATABASE_URL=sqlite+aiosqlite:///./dev.db

# Redis (Background-Worker + WebSocket Pub/Sub)
REDIS_URL=redis://localhost:6379/0
# Auf false setzen, um Redis-abhängige Features zu deaktivieren (z.B. Tests)
REDIS_ENABLED=true

# Observability
# SENTRY_DSN=
METRICS_ENABLED=true

# CORS (comma separated)
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
